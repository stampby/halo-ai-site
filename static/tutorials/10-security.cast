[14.6, "o", "\u001b[32m  ✓ SSHD config        \u001b[0m PermitRootLogin no, MaxAuthTries 3\r\n"]
[14.9, "o", "\u001b[32m  ✓ Unattended updates \u001b[0m pacman hook active\r\n"]
