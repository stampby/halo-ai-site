[2.00, "o", "\r\n"]
[2.2, "o", "#!/usr/bin/nft -f\r\n"]
[2.3, "o", "flush ruleset\r\n\r\n"]
[2.4, "o", "table inet filter {\r\n"]
[2.5, "o", "  chain input {\r\n"]
[2.6, "o", "    type filter hook input priority 0; policy drop;\r\n"]
[2.7, "o", "    iif lo accept\r\n"]
[2.75, "o", "    ct state established,related accept\r\n"]
[2.8, "o", "    ct state invalid drop\r\n"]
[2.85, "o", "    tcp dport 22 accept     # SSH\r\n"]
[2.9, "o", "    tcp dport 80 accept      # HTTP\r\n"]
[2.95, "o", "    tcp dport 443 accept     # HTTPS\r\n"]
[3.0, "o", "    ip saddr 192.168.50.0/24 accept  # LAN\r\n"]
[3.05, "o", "    counter drop\r\n"]
[3.1, "o", "  }\r\n"]
[3.15, "o", "  chain forward {\r\n"]
[3.2, "o", "    type filter hook forward priority 0; policy drop;\r\n"]
[3.25, "o", "  }\r\n"]
[3.3, "o", "  chain output {\r\n"]
[3.35, "o", "    type filter hook output priority 0; policy accept;\r\n"]
[3.4, "o", "  }\r\n"]
[3.45, "o", "}\r\n\r\n"]
[3.8, "o", "\u001b[32m[architect@ryzen ~]$\u001b[0m "]
